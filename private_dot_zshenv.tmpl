# Environment variables - Generated by chezmoi
# DO NOT EDIT MANUALLY - Edit private_dot_zshenv.tmpl instead

# Locale — set here (not in .zshrc) so non-interactive shells (scripts, scp,
# subprocesses spawned by editors) also get UTF-8. Many tools assume UTF-8 and
# break (or silently mojibake) without an explicit locale.
export LANG=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8

# mise shims — garante as versoes gerenciadas pelo mise tambem em shells
# NAO-interativos, scripts e processos que dao spawn em zsh. O `mise activate`
# no .zshrc cobre apenas o shell interativo; os shims cobrem o resto.
[[ -d "$HOME/.local/share/mise/shims" ]] && export PATH="$HOME/.local/share/mise/shims:$PATH"

# Node.js — confia nas CAs do System keychain do macOS.
# O Node ignora o keychain e usa CA bundle proprio, quebrando downloads de
# pacotes que fazem fetch no postinstall (tree-sitter-cli, playwright, etc.).
# O bundle abaixo e gerado pelo chezmoi script run_before_05-macos-node-ca-bundle.
{{- if eq .chezmoi.os "darwin" }}
{{- if not (has .machineName .personal_machines) }}
_node_ca_bundle="${XDG_STATE_HOME:-$HOME/.local/state}/node-ca-bundle.pem"
[ -r "$_node_ca_bundle" ] && export NODE_EXTRA_CA_CERTS="$_node_ca_bundle"
unset _node_ca_bundle
{{- end }}
{{- end }}

# OpenCode experimental features
export OPENCODE_EXPERIMENTAL_LSP_TOOL=true

# Planz — absolute path to the SQLite database the MCP server reads/writes.
# Defaults to ~/.local/share/planz/planz.db (matches planz's hardcoded fallback),
# but we set it explicitly so the MCP can resolve it before any planz code runs.
export PLANZ_DATABASE="${HOME}/.local/share/planz/planz.db"

# API tokens
# Resolved once from Bitwarden by `zsh-tokens-sync` into the file below
# (secrets stay in the vault, never in this repo). Sourcing a pre-rendered file
# keeps every shell startup instant — no `bw`/`python` at runtime. If the file
# is absent (vault never synced, or CI) any tokens already in the environment
# are used as-is. Refresh after rotating a token with:  zsh-tokens-sync
_zsh_tokens="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/tokens.zsh"
[ -r "$_zsh_tokens" ] && source "$_zsh_tokens"
unset _zsh_tokens
