#!/usr/bin/env bash
# Generate ~/.config/zsh/tokens.zsh from Bitwarden on first apply (and whenever
# the sync script changes). Installs bw and unlocks the vault if needed.
# Re-run `zsh-tokens-sync` by hand after rotating a token.
# sync script hash: {{ include "private_dot_local/bin/executable_zsh-tokens-sync" | sha256sum }}
set -euo pipefail

sync="{{ .chezmoi.homeDir }}/.local/bin/zsh-tokens-sync"
if [ ! -x "$sync" ]; then
  exit 0
fi

if ! command -v bw >/dev/null 2>&1; then
  echo "Bitwarden CLI (bw) nao encontrado — instalando..."
  if command -v brew >/dev/null 2>&1; then
    brew install bitwarden-cli
  elif command -v yay >/dev/null 2>&1; then
    yay -S --noconfirm bitwarden-cli
  elif command -v pacman >/dev/null 2>&1; then
    sudo pacman -S --noconfirm bitwarden-cli
  else
    echo "ERRO: Gerenciador de pacotes compativel nao encontrado. Instale o bw manualmente." >&2
    exit 1
  fi
fi

if ! bw unlock --check >/dev/null 2>&1; then
  echo "Bitwarden vault bloqueado — desbloqueando para gerar tokens..."
  session="$(bw unlock --raw)" || {
    echo "ERRO: Falha ao desbloquear o vault. Execute 'bw unlock' manualmente." >&2
    exit 1
  }
  export BW_SESSION="$session"
fi

"$sync"
