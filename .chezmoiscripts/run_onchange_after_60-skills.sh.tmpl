#!/usr/bin/env bash
# Re-run whenever the skill-lock changes.
# skill-lock hash: {{ include "dot_agents/dot_skill-lock.json" | sha256sum }}
set -euo pipefail

command -v skills >/dev/null 2>&1 || exit 0
[[ -f "$HOME/.agents/.skill-lock.json" ]] || exit 0

echo ":: skills install (skill-lock changed)"

# Extract unique source repos from the lock file and reinstall each one.
# The lock format is: { "skills": { "<name>": { "source": "owner/repo", ... } } }
failed=0
while IFS= read -r repo; do
    [[ -z "$repo" ]] && continue
    echo "  adding skills from $repo"
    install_output=$(skills add "$repo" -a opencode -g -y 2>&1) && install_exit=0 || install_exit=$?
    if [[ $install_exit -ne 0 ]]; then
        echo "  $repo: FAILED (exit $install_exit)" >&2
        echo "$install_output" >&2
        failed=1
    fi
done < <(
    python3 - <<'EOF'
import json, sys
lock = json.load(open(f"{__import__('os').environ['HOME']}/.agents/.skill-lock.json"))
repos = sorted({v["source"] for v in lock.get("skills", {}).values()})
print("\n".join(repos))
EOF
)

if [[ $failed -ne 0 ]]; then
    echo ":: skills install completed with errors" >&2
    exit 1
fi
