#compdef oc-provider

local -a commands providers profiles

commands=(
  'status:mostrar provider/profile atuais'
  'reset:restaurar provider/profile padrão'
  'dry-run:mostrar mudança sem aplicar'
)

# Resolve providers from chezmoi data (same source as the oc-provider script).
# Falls back to a hardcoded list if chezmoi/jq are unavailable or parsing fails,
# so completion still works on a fresh machine before chezmoi has been run.
providers=()
if (( ${+commands[chezmoi]} )) && (( ${+commands[jq]} )); then
  local -a _dyn
  _dyn=( ${(f)"$(chezmoi data --format=json 2>/dev/null \
    | jq -r '.opencode.models | keys[]' 2>/dev/null)"} )
  if (( ${#_dyn} > 0 )); then
    providers=( "${_dyn[@]}" )
  fi
fi
if (( ${#providers} == 0 )); then
  # Fallback — kept in sync with .chezmoidata/opencode_providers.toml
  providers=(
    'deepseek:DeepSeek'
    'minimax:MiniMax'
    'moonshotai:Kimi (Moonshot)'
    'openai:OpenAI'
    'opencode:OpenCode Zen'
    'xiaomi:Xiaomi (mimo)'
    'zai:Zhipu AI (GLM)'
    'zen-free:OpenCode Zen Free (zero cost)'
  )
fi

profiles=(
  'optimized:Economia de ~28% (medium para rotineiras, high para críticas)'
  'moderate:Alias para optimized'
  'super:Economia máxima de ~38% (low/medium para maioria)'
  'ultra:Custo mínimo: menor esforço suportado'
  'recommended:Tiers recomendados pelo Oh My OpenAgent'
)

if (( CURRENT == 2 )); then
  _describe 'command' commands
  _describe 'provider' providers
  return
fi

case "${words[2]-}" in
  status|reset)
    return
    ;;
  dry-run)
    if (( CURRENT == 3 )); then
      _describe 'provider' providers
    elif (( CURRENT == 4 )); then
      _describe 'profile' profiles
    fi
    return
    ;;
  *)
    if (( CURRENT == 3 )); then
      _describe 'profile' profiles
    fi
    ;;
esac
